# 皮皮虾模拟器 v6.1.0 配置模板

# 数据库配置
DB_FILE=data.db

# 下载目录(相对于项目根目录)
DOWNLOAD_DIR=downloads

# 日志目录(相对于项目根目录)
LOG_DIR=logs

# 应用信息
APP_NAME=皮皮虾模拟器
APP_VERSION=6.1.0

# API配置
API_BASE_URL=https://h5.pipix.com
API_URL=https://is.snssdk.com

# 请求超时设置(秒)
REQUEST_TIMEOUT=15
DOWNLOAD_TIMEOUT=60

# 下载块大小(字节)
CHUNK_SIZE=8192

# 最大重试次数
MAX_RETRY=3
